{
  "extends": [
    "github>nuxt/renovate-config-nuxt"
  ],
  "timezone": "Asia/Shanghai",
  "schedule": [
    "* 6-9 * * 1"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepTypes": [
        "resolutions"
      ],
      "enabled": false
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ]
}
