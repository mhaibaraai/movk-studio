# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=

# Mapbox/天地图浏览器端 token，属于 public runtime config，容器启动时注入即可，无需重新构建镜像
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NUXT_PUBLIC_MAPBOX_TIANDITU_TOKEN=
# 天地图地点检索服务专用：控制台需申请「服务端」类型 key（IP 白名单校验），与上面浏览器端 key 不同
NUXT_TIANDITU_API_TOKEN=

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
# GitHub OAuth client ID
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# AI Gateway API Key
AI_GATEWAY_API_KEY=

# Alibaba(Qwen)DashScope API Key
ALIBABA_API_KEY=
# 可选:留空用 SDK 默认(国际站),大陆站点填 https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_BASE_URL=

# 可选:容器出站走代理(如 http://host.docker.internal:7893),本地开发留空
HTTPS_PROXY=
